{
  "schema_version": 2,
  "projection_name": "rp-host-projection",
  "host": {
    "name": "repoprompt",
    "display_name": "RepoPrompt",
    "stored_runtime_key": "host_contract",
    "default_variant": "rp/manual",
    "variants": {
      "manual": {
        "adapter": "rp",
        "mode": "manual",
        "capabilities": {
          "supports_auto_execution": false,
          "requires_explicit_review_handoff": true
        },
        "review": {
          "required_run_artifacts": [
            "verify-report.json"
          ],
          "required_report_string_fields": [
            "summary",
            "mode",
            "prompt_file"
          ],
          "required_report_list_fields": [
            "issues"
          ],
          "expected_report_mode": "manual",
          "linked_report_artifact_field": "prompt_file"
        },
        "native_runtime": {
          "enabled": true,
          "command_candidates": [
            "rp",
            "rp-cli"
          ],
          "install_hint": "Install the real RepoPrompt app / MCP CLI runtime on PATH (for example `rp` or `rp-cli`) to try RP experimental auto/native execution; manual handoff remains the stable supported path.",
          "protocol_version": 1
        },
        "bridge": {
          "enabled": true,
          "default_mode": "manual-assist",
          "supported_modes": [
            "disabled",
            "manual-assist",
            "managed-agent"
          ],
          "command_candidates": [
            "rp",
            "rp-cli"
          ],
          "install_hint": "Install the real RepoPrompt app / MCP CLI runtime on PATH (for example `rp` or `rp-cli`) to use the experimental RP bridge (manual-assist or managed-agent); manual handoff remains the stable supported path."
        }
      },
      "auto": {
        "adapter": "rp",
        "mode": "auto",
        "capabilities": {
          "supports_auto_execution": true,
          "requires_explicit_review_handoff": false
        },
        "review": {
          "required_run_artifacts": [
            "verify-report.json"
          ],
          "required_report_string_fields": [
            "summary",
            "mode",
            "response_file"
          ],
          "required_report_list_fields": [
            "issues"
          ],
          "expected_report_mode": "auto",
          "linked_report_artifact_field": "response_file"
        },
        "native_runtime": {
          "enabled": true,
          "command_candidates": [
            "rp",
            "rp-cli"
          ],
          "install_hint": "Install the real RepoPrompt app / MCP CLI runtime on PATH (for example `rp` or `rp-cli`) to try RP experimental auto/native execution; manual handoff remains the stable supported path.",
          "protocol_version": 1
        },
        "bridge": {
          "enabled": false,
          "default_mode": "disabled",
          "supported_modes": [
            "disabled"
          ],
          "command_candidates": [],
          "install_hint": null
        }
      }
    }
  },
  "artifacts": {
    "bundle": "rp-bundle.md",
    "install_surface": "install-surface.json",
    "manifest": "manifest.json"
  },
  "install_surface": {
    "install_strategy": "use_compiled_output_directory",
    "default_output_dir": ".rp/compiled",
    "generated_asset_roles": [
      "bundle",
      "projection",
      "install_surface",
      "manifest"
    ],
    "external_assets": []
  },
  "commands": {
    "plan": "uv run aiwf run plan --task .ai/tasks/<task>.md --adapter rp",
    "implement": "uv run aiwf run implement --task .ai/tasks/<task>.md --adapter rp",
    "review": "uv run aiwf run review --run-id <run_id>",
    "resume": "uv run aiwf resume <run_id>"
  },
  "workflow_contract": {
    "plan": {
      "entrypoint": "uv run aiwf run plan --task .ai/tasks/<task>.md --adapter rp",
      "primary_artifacts": [
        "context-pack.md",
        "exec-plan.md"
      ],
      "auto_entrypoint": "uv run aiwf run plan --task .ai/tasks/<task>.md --adapter rp --auto"
    },
    "implement": {
      "entrypoint": "uv run aiwf run implement --task .ai/tasks/<task>.md --adapter rp",
      "manual_handoff_artifact": "rp-agent-implement-prompt.md",
      "bridge_seeding_artifact": "rp-bridge-seeding.json",
      "bridge_modes_supported": [
        "disabled",
        "manual-assist",
        "managed-agent"
      ],
      "auto_stage_output_artifact": "rp-agent-implement-response.md",
      "resume_boundary": "Use `uv run aiwf resume <run_id>` after manual RepoPrompt implement handoff. This manual handoff flow is the stable/default RP path.",
      "auto_entrypoint": "uv run aiwf run implement --task .ai/tasks/<task>.md --adapter rp --auto"
    },
    "review": {
      "entrypoint": "uv run aiwf run review --run-id <run_id>",
      "requires_status": "needs_review",
      "required_run_artifacts": [
        "verify-report.json"
      ],
      "report_contract": {
        "manual": {
          "required_run_artifacts": [
            "verify-report.json"
          ],
          "required_report_string_fields": [
            "summary",
            "mode",
            "prompt_file"
          ],
          "required_report_list_fields": [
            "issues"
          ],
          "expected_report_mode": "manual",
          "linked_report_artifact_field": "prompt_file"
        },
        "auto": {
          "required_run_artifacts": [
            "verify-report.json"
          ],
          "required_report_string_fields": [
            "summary",
            "mode",
            "response_file"
          ],
          "required_report_list_fields": [
            "issues"
          ],
          "expected_report_mode": "auto",
          "linked_report_artifact_field": "response_file"
        }
      }
    },
    "resume": {
      "entrypoint": "uv run aiwf resume <run_id>",
      "restores_run_metadata": [
        "host_contract"
      ]
    }
  },
  "projection_inputs": {
    "count": 3,
    "entry_keys": [
      "kind",
      "logical_name",
      "sha256",
      "source_path"
    ],
    "kind_counts": {
      "gate": 1,
      "policy": 1,
      "runbook": 1
    }
  },
  "projection_hash_keys": [
    "bundle_sha256"
  ]
}
