{
  "schema_version": 2,
  "projection_name": "claude-host-projection",
  "host": {
    "name": "claude_code",
    "display_name": "Claude Code",
    "stored_runtime_key": "host_contract",
    "default_variant": "claude/manual",
    "variants": {
      "manual": {
        "adapter": "claude",
        "mode": "manual",
        "capabilities": {
          "supports_auto_execution": true,
          "requires_explicit_review_handoff": true
        },
        "review": {
          "required_run_artifacts": [
            "verify-report.json"
          ],
          "required_report_string_fields": [
            "summary",
            "mode",
            "prompt_file"
          ],
          "required_report_list_fields": [
            "issues"
          ],
          "expected_report_mode": "manual",
          "linked_report_artifact_field": "prompt_file"
        },
        "native_runtime": {
          "enabled": false,
          "command_candidates": [],
          "install_hint": null
        },
        "bridge": {
          "enabled": false,
          "default_mode": "disabled",
          "supported_modes": [
            "disabled"
          ],
          "command_candidates": [],
          "install_hint": null,
          "allows_mutations": false,
          "destructive_capabilities": []
        }
      },
      "auto": {
        "adapter": "claude",
        "mode": "auto",
        "capabilities": {
          "supports_auto_execution": true,
          "requires_explicit_review_handoff": false
        },
        "review": {
          "required_run_artifacts": [
            "verify-report.json"
          ],
          "required_report_string_fields": [
            "summary",
            "mode",
            "response_file"
          ],
          "required_report_list_fields": [
            "issues"
          ],
          "expected_report_mode": "auto",
          "linked_report_artifact_field": "response_file"
        },
        "native_runtime": {
          "enabled": false,
          "command_candidates": [],
          "install_hint": null
        },
        "bridge": {
          "enabled": false,
          "default_mode": "disabled",
          "supported_modes": [
            "disabled"
          ],
          "command_candidates": [],
          "install_hint": null,
          "allows_mutations": false,
          "destructive_capabilities": []
        }
      }
    }
  },
  "artifacts": {
    "bundle": "claude-bundle.md",
    "install_surface": "install-surface.json",
    "manifest": "manifest.json"
  },
  "install_surface": {
    "install_strategy": "use_compiled_output_directory",
    "default_output_dir": ".claude/compiled",
    "generated_asset_roles": [
      "bundle",
      "projection",
      "install_surface",
      "manifest"
    ],
    "external_assets": [
      {
        "path": ".claude/skills",
        "owner": "handwritten",
        "managed_by_compiler": false,
        "rationale": "Claude skill prompts remain handwritten source assets; compile only owns generated bundle artifacts under .claude/compiled."
      }
    ]
  },
  "commands": {
    "plan": "uv run aiwf run plan --task .ai/tasks/<task>.md --adapter claude",
    "implement": "uv run aiwf run implement --task .ai/tasks/<task>.md --adapter claude",
    "review": "uv run aiwf run review --run-id <run_id>",
    "resume": "uv run aiwf resume <run_id>"
  },
  "workflow_contract": {
    "plan": {
      "entrypoint": "uv run aiwf run plan --task .ai/tasks/<task>.md --adapter claude",
      "primary_artifacts": [
        "context-pack.md",
        "exec-plan.md"
      ]
    },
    "implement": {
      "entrypoint": "uv run aiwf run implement --task .ai/tasks/<task>.md --adapter claude",
      "manual_handoff_artifact": "claude-implement-prompt.md",
      "resume_boundary": "Use `uv run aiwf resume <run_id>` after manual implement handoff."
    },
    "review": {
      "entrypoint": "uv run aiwf run review --run-id <run_id>",
      "requires_status": "needs_review",
      "required_run_artifacts": [
        "verify-report.json"
      ],
      "report_contract": {
        "manual": {
          "required_run_artifacts": [
            "verify-report.json"
          ],
          "required_report_string_fields": [
            "summary",
            "mode",
            "prompt_file"
          ],
          "required_report_list_fields": [
            "issues"
          ],
          "expected_report_mode": "manual",
          "linked_report_artifact_field": "prompt_file"
        },
        "auto": {
          "required_run_artifacts": [
            "verify-report.json"
          ],
          "required_report_string_fields": [
            "summary",
            "mode",
            "response_file"
          ],
          "required_report_list_fields": [
            "issues"
          ],
          "expected_report_mode": "auto",
          "linked_report_artifact_field": "response_file"
        }
      }
    },
    "resume": {
      "entrypoint": "uv run aiwf resume <run_id>",
      "restores_run_metadata": [
        "host_contract"
      ]
    }
  },
  "projection_inputs": {
    "count": 3,
    "entry_keys": [
      "kind",
      "logical_name",
      "sha256",
      "source_path"
    ],
    "kind_counts": {
      "gate": 1,
      "policy": 1,
      "runbook": 1
    }
  },
  "projection_hash_keys": [
    "bundle_sha256"
  ]
}
